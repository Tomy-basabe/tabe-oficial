{
    "redirects": [
        {
            "source": "/auth",
            "has": [
                {
                    "type": "host",
                    "value": "tabe-oficial.vercel.app"
                }
            ],
            "destination": "https://www.tabe.software/registro",
            "permanent": true
        },
        {
            "source": "/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "tabe-oficial.vercel.app"
                }
            ],
            "destination": "https://www.tabe.software/$1",
            "permanent": true
        },
        {
            "source": "/auth",
            "destination": "/registro",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/sitemap.xml",
            "headers": [
                { "key": "Content-Type", "value": "application/xml" }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                { "key": "Content-Type", "value": "text/plain" }
            ]
        },
        {
            "source": "/ads.txt",
            "headers": [
                { "key": "Content-Type", "value": "text/plain" }
            ]
        },
        {
            "source": "/(sw.js|manifest.json|manifest.webmanifest)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
                { "key": "Service-Worker-Allowed", "value": "/" }
            ]
        }
    ]
}
