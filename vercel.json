{
    "redirects": [
        {
            "source": "/auth",
            "destination": "/registro",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/sitemap.xml",
            "headers": [
                { "key": "Content-Type", "value": "application/xml" }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                { "key": "Content-Type", "value": "text/plain" }
            ]
        },
        {
            "source": "/ads.txt",
            "headers": [
                { "key": "Content-Type", "value": "text/plain" }
            ]
        }
    ]
}